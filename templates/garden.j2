{# All code is based on the CS340 starter code or original unless otherwise noted. #}

{% extends "main.j2" %}
{% block content %}

<div class="page">
    <h1>View All Gardens</h1>

    {# READ table #}
    <table>
        <thead>
            {# For the table header row, we print the DB attribute names #}
            <tr>
                {% if gardens and gardens|length > 0 %}
                    {% for key in gardens[0].keys() %}
                        <th>{{ key }}</th>
                    {% endfor %}
                {% else %}
                    <th>id</th>
                    <th>description</th>
                    <th>location</th>
                    <th>owner</th>
                {% endif %}
                <th></th>
            </tr>
        </thead>

        <tbody>
            {% for garden in gardens %}
                <tr>
                    <td>{{ garden.id }}</td>
                    <td>{{ garden.description }}</td>
                    <td>{{ garden.location }}</td>
                    <td>{{ garden.owner }}</td>
                    {#
                        Citation for use of AI Tools:
                        Date: 2/19/2026
                        Prompts used to generate on click confirmation for delete:
                        1. Help me write a on click confirmation for a delete button in html
                        AI Source URL: https://gemini.google.com/
                    #}
                    {# DELETE link - Styled as a button to fix the multiple-click issue #}
                    <td>
                        <a href="javascript:void(0)" 
                           class="delete-btn-link"
                           onclick="if(confirm('Are you sure?')) { 
                               var f = document.createElement('form');
                               f.method='POST';
                               f.action='/delete-garden/{{ garden.id }}';
                               document.body.appendChild(f);
                               f.submit();
                           }">Delete</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {# CREATE form #}
    <h2>Create a garden</h2>
    <form class="cuForm" id="create_garden" method="POST">
        <label for="create_garden_description">Description: </label>
        <input type="text" name="create_garden_description" id="create_garden_description"><br>

        <label for="create_garden_location">Location: </label>
        <input type="text" name="create_garden_location" id="create_garden_location" required><br>

        <label for="create_garden_owner">Owner: </label>
        <select name="create_garden_owner" id="create_garden_owner" required>
            <option value="" disabled selected hidden>Select</option>
            {% for user in users %}
                <option value="{{user['user_id']}}">
                    {{user['owner']}}
                </option>
            {% endfor %}
        </select><br>
        
        <input type="submit" value="Submit">
    </form>
</div>

{% endblock %}