{# All code is based on the CS340 starter code or original unless otherwise noted. #}

{% extends "main.j2" %}
{% block content %}
{# Citation for use of AI Tools:
# Date: 3/4/2026
# Prompts used for help with date input validation:
# 1. I pasted the HTML form code into the prompt and asked it to help me generate the
# the renderings to show the error on the same page
#}
{% if error %}
<div style="background-color: #fce4e4; border: 1px solid #f03e3e; color: #d63031; padding: 15px; border-radius: 4px; margin-bottom: 20px;">
    <strong>Validation Error:</strong> {{ error }}
</div>
{% endif %}

<div class="page">
    <h1>View All Of My Plants</h1>

    {# READ table #}
    {# 
        Citation for use of AI Tools:
        Date: 2/19/2026
        Prompts used to refactor Jinja table:
        I need help resolving the 'tuple object has no element 0' error.
        AI Source URL: https://gemini.google.com/ 
    #}
    <table>
        <thead>
            <tr>
                {% if my_plants and my_plants|length > 0 %}
                    {% for key in my_plants[0].keys() %}
                        <th>{{ key }}</th>
                    {% endfor %}
                {% else %}
                    <th>id</th>
                    <th>species</th>
                    <th>category</th>
                    <th>date planted</th>
                    <th>quantity</th>
                    <th>bed</th>
                {% endif %}
                <th></th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            {% for plant_in_bed in my_plants %}
                <tr>
                    <td>{{ plant_in_bed.id }}</td>
                    <td>{{ plant_in_bed.species }}</td>
                    <td>{{ plant_in_bed['plant category'] }}</td>
                    <td>{{ plant_in_bed['date planted'] }}</td>
                    <td>{{ plant_in_bed['plant quantity'] }}</td>
                    <td>{{ plant_in_bed.bed }}</td>
                    <td>
                        <a href="/edit-plant-in-bed/{{ plant_in_bed.id }}">
                            <button type="button">Edit</button>
                        </a>
                    </td>

                    {# DELETE form #}
                    {# 
                        Citation for use of AI Tools:
                        Date: 2/19/2026
                        Prompts used to refactor Jinja table and delete form:
                        1. I need help writing a delete route for the plant-in-bed object (formatting the HTML table and form).
                        2. Help me format the delete button inside the table.
                        AI Source URL: https://gemini.google.com/ 
                    #}
                    {#
                        Citation for use of AI Tools:
                        Date: 3/04/2026
                        Prompts used to refactor Jinja table and delete form:
                        1. Help me resolve an issue where the delete button requires multiple clicks to trigger.
                        2. Refactor the HTML form submission to use a styled link and dynamic JavaScript form creation to bypass browser event hijacking.
                        AI Source URL: https://gemini.google.com/
                    #}
                    <td>
                        <a href="javascript:void(0)" 
                           class="delete-btn-link"
                           onclick="if(confirm('Are you sure?')) { 
                               var f = document.createElement('form');
                               f.method='POST';
                               f.action='/delete-plant-in-bed/{{ plant_in_bed.id }}';
                               document.body.appendChild(f);
                               f.submit();
                           }">Delete</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {# CREATE form #}
    <h2>Add a new Plant</h2>
    <form class="cuForm" id="create_plant_form" method="POST">
        <label for="create_plant_species">Species: </label>
        <select name="create_plant_species" id="create_plant_species" required>
            <option value="" disabled selected hidden>Select a Species</option>
            {% for plant in plants_dropdown %}
                <option value="{{plant['plant_id']}}" required>{{plant['species']}}</option>
            {% endfor %}
        </select>

        <label for="create_plant_bed">Bed: </label>
        <select name="create_plant_bed" id="create_plant_bed" required>
            <option value="" disabled selected hidden>Select a Bed</option>
            {% for bed in beds_dropdown %}
                <option value="{{bed['bed_id']}}" required>{{bed['label']}}</option>
            {% endfor %}
        </select>

        <label for="create_date_planted">Date Planted: </label>
        <input type="date" name="create_date_planted" id="create_date_planted" required>

        <label for="create_plant_quantity">Quantity: </label>
        <input type="number" name="create_plant_quantity" id="create_plant_quantity" min="0" required>

        <input type="submit">
    </form>
</div>

{% endblock %}