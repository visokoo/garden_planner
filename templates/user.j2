{% extends "main.j2" %}
{% block content %}

<div class="page">
    <h1>View All Users</h1>

    {# READ table #}
    <table>
        <thead>
            {# For the table header row, we print the DB attribute names #}
            <tr>
                {% if users and users|length > 0 %}
                    {% for key in users[0].keys() %}
                        <th>{{ key }}</th>
                    {% endfor %}
                {% else %}
                    <th>id</th>
                    <th>first name</th>
                    <th>last name</th>
                {% endif %}
                <th></th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            {# For each row, print the id, fname, lname #}
            {% for user in users %}
                <tr>
                    <td>{{ user.id }}</td>
                    <td>{{ user['first name'] }}</td>
                    <td>{{ user['last name'] }}</td>
                    <td>
                        <a href="/edit-user/{{ user.id }}">
                            <button type="button">Edit</button>
                        </a>
                    </td>

                    {# DELETE link - Styled as a button to fix the multiple-click issue #}
                    <td>
                        <a href="javascript:void(0)" 
                           class="delete-btn-link"
                           onclick="if(confirm('Are you sure?')) { 
                               var f = document.createElement('form');
                               f.method='POST';
                               f.action='/delete-user/{{ user.id }}';
                               document.body.appendChild(f);
                               f.submit();
                           }">Delete</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {# CREATE form #}
    <h2>Create a User</h2>
    <form class="cuForm" id="create_user_form" method="POST"> 
        <label for="create_user_first_name">First Name: </label> 
        <input type="text" name="create_user_first_name" id="create_user_first_name" required> 

        <label for="create_user_last_name">Last Name: </label> 
        <input type="text" name="create_user_last_name" id="create_user_last_name" required> 

        <input type="submit" value="Submit"> 
    </form>
</div>

{% endblock %}