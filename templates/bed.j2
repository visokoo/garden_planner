{% extends "main.j2" %}
{% block content %}

<div class="page">
    <h1>View All Beds</h1>

    {# READ table #}
    <table>
        <thead>
            {# For the table header row, we print the DB attribute names #}
            <tr>
                {% if bed and bed|length > 0 %}
                    {% for key in beds[0].keys() %}
                        {% if key == 'garden_id' %}
                            <th>{{ key }}</th>
                        {% else %}
                            <th>{{ key }}</th>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <th>id</th>
                    <th>label</th>
                    <th>length (inches)</th>
                    <th>width (inches)</th>
                    <th>garden</th>
                {% endif %}
                <th></th>
            </tr>
        </thead>

        <tbody>
            {% for bed in beds %}
            <tr>
                <td>{{ bed.id }}</td>
                <td>{{ bed.label }}</td>
                <td>{{ bed['length (inches)'] }}</td>
                <td>{{ bed['width (inches)'] }}</td>
                <td>
                {% for garden in gardens_dropdown %}
                    {% if garden.garden_id == bed.garden %}
                        {{ garden.location }}
                    {% endif %}
                {% endfor %}
                </td>
                {# DELETE form #}
                <form id="delete_bed_form" action="/delete-bed/{{ bed.id }}" method="POST">
                    <input type="hidden" name="delete_bed_id" value="{{ bed.id }}">
                    <td>
                        <button type="submit" onclick="return confirm('Are you sure?')">
                            Delete
                        </button>
                    </td>
                </form>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {# CREATE form #}
    <h2>Create a Bed</h2>
    <form class="cuForm" id="create_bed_form" method="POST">
        <label for="create_bed_label">Label: </label>
        <input type="text" name="create_bed_label" id="create_bed_label" required>

        <label for="create_bed_length">Length: </label>
        <input type="number" name="create_bed_length" id="create_bed_length">

        <label for="create_bed_width">Width: </label>
        <input type="number" name="create_bed_width" id="create_bed_width">

        <label for="create_bed_garden">Garden: </label>
        <select name="create_bed_garden" id="create_bed_garden" required>
        <option value="NULL" selected>Select a Garden</option>
        {% for garden in gardens_dropdown %}
        <option value="{{ garden['garden_id'] }}"> 
            {{ garden['location'] }} 
        </option>
        {% endfor %}
    </select>

        <input type="submit">
    </form>
</div>

{% endblock %}
