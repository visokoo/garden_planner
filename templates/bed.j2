{# All code is based on the CS340 starter code or original unless otherwise noted. #}
{% extends "main.j2" %}
{% block content %}

<div class="page">
    <h1>View All Beds</h1>

    {# READ table #}
    <table>
        <thead>
            {# For the table header row, we print the DB attribute names #}
            <tr>
                {% if beds and beds|length > 0 %}
                    {% for key in beds[0].keys() %}
                        <th>{{ key }}</th>
                    {% endfor %}
                {% else %}
                    <th>id</th>
                    <th>label</th>
                    <th>length (inches)</th>
                    <th>width (inches)</th>
                    <th>garden</th>
                {% endif %}
                <th></th>
            </tr>
        </thead>

        <tbody>
            {% for bed in beds %}
                <tr>
                    <td>{{ bed.id }}</td>
                    <td>{{ bed.label }}</td>
                    <td>{{ bed['length (inches)'] }}</td>
                    <td>{{ bed['width (inches)'] }}</td>
                    <td>
                        {% for garden in gardens_dropdown %}
                            {% if garden.garden_id == bed.garden %}
                                {{ garden.location }}
                            {% endif %}
                        {% endfor %}
                    </td>
                    {#
                        Citation for use of AI Tools:
                        Date: 2/19/2026
                        Prompts used to generate on click confirmation for delete:
                        1. Help me write a on click confirmation for a delete button in html
                        AI Source URL: https://gemini.google.com/
                    #}
                    {# DELETE form - Nested inside td to fix submission logic #}
                    <td>
                        <a href="javascript:void(0)" 
                           class="delete-btn-link"
                           onclick="if(confirm('Are you sure?')) { 
                               var f = document.createElement('form');
                               f.method='POST';
                               f.action='/delete-bed/{{ bed.id }}';
                               document.body.appendChild(f);
                               f.submit();
                           }">Delete</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {# CREATE form #}
    <h2>Create a Bed</h2>
    <form class="cuForm" id="create_bed_form" method="POST">
        <label for="create_bed_label">Label: </label>
        <input type="text" name="create_bed_label" id="create_bed_label" required>

        <label for="create_bed_length">Length: </label>
        <input type="number" name="create_bed_length" id="create_bed_length" required>

        <label for="create_bed_width">Width: </label>
        <input type="number" name="create_bed_width" id="create_bed_width" required>

        <label for="create_bed_garden">Garden: </label>
        <select name="create_bed_garden" id="create_bed_garden" required>
            <option value="" disabled selected hidden>Select a Garden</option>
            {% for garden in gardens_dropdown %}
                <option value="{{ garden['garden_id'] }}"> 
                    {{ garden['location'] }} 
                </option>
            {% endfor %}
        </select>

        <input type="submit" value="Submit">
    </form>
</div>

{% endblock %}