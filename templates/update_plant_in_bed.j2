{% extends "main.j2" %}
{% block content %}
{# Citation for use of AI Tools:
# Date: 3/4/2026
# Prompts used for help with date input validation:
# 1. I pasted the HTML form code into the prompt and asked it to help me generate the
# the renderings to show the error on the same page
#}
{% if error %}
<div style="background-color: #fce4e4; border: 1px solid #f03e3e; color: #d63031; padding: 15px; border-radius: 4px; margin-bottom: 20px;">
    <strong>Validation Error:</strong> {{ error }}
</div>
{% endif %}
<div class="page">
    <h2>Update My Plant</h2>

    <form action="/edit-plant-in-bed/{{ id }}" method="POST" class="cuForm">
        
        <input type="hidden" name="id" value="{{ id }}">

        <label for="plant_id">Plant Species: </label>
        <select name="plant_id" id="plant_id" required>
            {% for plant in plants_dropdown %}
                <option value="{{ plant.plant_id }}" 
                    {% if plant.plant_id == plant_data.plant_id %} selected {% endif %}>
                    {{ plant.species }}
                </option>
            {% endfor %}
        </select>

        <label for="bed_id">Bed Label: </label>
        <select name="bed_id" id="bed_id" required>
            {% for bed in beds_dropdown %}
                <option value="{{ bed.bed_id }}" 
                    {% if bed.bed_id == plant_data.bed_id %} selected {% endif %}>
                    {{ bed.label }}
                </option>
            {% endfor %}
        </select>

        <label for="date_planted">Date Planted: </label>
        <input type="date" name="date_planted" id="date_planted" value="{{ plant_data.date_planted }}" required>

        <label for="plant_quantity">Quantity: </label>
        <input type="number" name="plant_quantity" id="plant_quantity" min="0" value="{{ plant_data.plant_quantity }}">

        <button type="submit">Submit</button>
    </form>
</div>

{% endblock %}
